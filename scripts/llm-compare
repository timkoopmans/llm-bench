#!/usr/bin/env bash
# 3-way iTerm2 comparison: Claude API | Blackwell vast vllm | 3090 idc-1 llama.cpp.
# Reads ../.env for endpoints + keys. Pane IDs cached in /tmp/llm-compare-panes.
#
# Usage:
#   llm-compare              # if panes exist: rerun in them; else: start fresh
#   llm-compare start        # force-create new panes (control top + 3 cols bottom)
#   llm-compare go ["prompt"]# rerun in existing panes (default subcmd)
#   llm-compare reset        # forget cached pane IDs

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="${SCRIPT_DIR}/../.env"
set -a; . "$ENV_FILE"; set +a

STATE_FILE=/tmp/llm-compare-panes
STREAM="${SCRIPT_DIR}/llm_stream.py"
SPEC_FILE="${SPEC_FILE:-${SCRIPT_DIR}/specs/lfucache.py}"
# Resolve to absolute path — iTerm panes inherit different cwd, relative paths break.
case "$SPEC_FILE" in
  /*) ;;
  *)  SPEC_FILE="$(cd "$(dirname "$SPEC_FILE")" && pwd)/$(basename "$SPEC_FILE")" ;;
esac
[[ -f "$SPEC_FILE" ]] || { echo "SPEC_FILE not found: $SPEC_FILE" >&2; exit 1; }

# Single canonical task for repeatable spec comparison.
# Same prompt every run (cache-busted via nonce in write_prompt).
# Read canonical spec; prompt asks model to implement it to satisfy.
SPEC_SRC="$(cat "$SPEC_FILE")"
DEFAULT_PROMPT="Implement the Python class required by the canonical unittest spec below. Read the module docstring + test method names + assertions to understand the required API and semantics. Output ONLY the class implementation — DO NOT include any tests, do NOT add 'if __name__' main block, do NOT redefine anything from the spec. Your code will be concatenated above the spec and the spec will be executed.

\`\`\`python
${SPEC_SRC}
\`\`\`

CRITICAL: Every test in the spec MUST pass. Mentally walk through each test against your implementation before finalising. Handle every edge case the tests cover (capacity=0, ties, frequency bookkeeping, etc.). The score is N_passed / N_total — anything less than full is a failure."

if [[ "${EXPAND:-0}" == "1" ]]; then
  GUIDE_FILE=$("${SCRIPT_DIR}/expand_prompt.py" "$SPEC_FILE") || { echo "expand_prompt.py failed" >&2; exit 1; }
  GUIDE_SRC="$(cat "$GUIDE_FILE")"
  DEFAULT_PROMPT="${DEFAULT_PROMPT}

--- IMPLEMENTATION GUIDE (senior engineer's notes; follow these) ---
${GUIDE_SRC}
--- END GUIDE ---"
  echo "expanded with: $GUIDE_FILE"
fi

CLAUDE_MODEL="${CLAUDE_MODEL:-claude-sonnet-4-6}"
IDC_HOST="${LLM_HOST:-idc-1}"
IDC_PORT="${LLM_PORT:-8001}"
IDC_MODEL="${LLM_MODEL_NAME:-unsloth/Qwen3.6-35B-A3B}"
VAST_HOST="${BLACKWELL_HOST:?BLACKWELL_HOST not set}"
VAST_PORT="${BLACKWELL_PORT:?BLACKWELL_PORT not set}"
VAST_MODEL="${BLACKWELL_MODEL_NAME:-qwen36}"
: "${ANTHROPIC_API_KEY:?ANTHROPIC_API_KEY not set}"

MAX_TOKENS="${MAX_TOKENS:-32768}"
QWEN_THINKING="${QWEN_THINKING:-on}"   # on|off|auto — drives chat_template_kwargs.enable_thinking
COUNTDOWN="${COUNTDOWN:-5}"
RUNNER="${RUNNER:-${SCRIPT_DIR}/../.venv/bin/python3}"
[[ -x "$RUNNER" ]] || RUNNER="python3"
LOG_FILE="${LOG_FILE:-${SCRIPT_DIR}/../results.jsonl}"
WALL_TIMEOUT="${WALL_TIMEOUT:-45}"

# Per-backend sampling. Defaults match each model's recommended settings.
# Claude: deterministic (temp 0). Qwen3.6 thinking precise-coding (Unsloth guide):
# temp 0.6, top_p 0.95, top_k 20, min_p 0, presence 0. Override any via env.
CLAUDE_TEMPERATURE="${CLAUDE_TEMPERATURE:-${TEMPERATURE:-0}}"
CLAUDE_TOP_P="${CLAUDE_TOP_P:-${TOP_P:-}}"

QWEN_TEMPERATURE="${QWEN_TEMPERATURE:-${TEMPERATURE:-0.6}}"
QWEN_TOP_P="${QWEN_TOP_P:-${TOP_P:-0.95}}"
QWEN_TOP_K="${QWEN_TOP_K:-20}"
QWEN_MIN_P="${QWEN_MIN_P:-0}"
QWEN_PRES_PENALTY="${QWEN_PRES_PENALTY:-${PRES_PENALTY:-0}}"
QWEN_FREQ_PENALTY="${QWEN_FREQ_PENALTY:-${FREQ_PENALTY:-0.5}}"  # discourage n-gram repeats in reasoning loops

claude_sampling() {
  local s="--temperature ${CLAUDE_TEMPERATURE} --wall-timeout ${WALL_TIMEOUT}"
  [[ -n "$CLAUDE_TOP_P" ]] && s="${s} --top-p ${CLAUDE_TOP_P}"
  echo "$s"
}
qwen_sampling() {
  local s="--temperature ${QWEN_TEMPERATURE} --wall-timeout ${WALL_TIMEOUT}"
  [[ -n "$QWEN_TOP_P" ]]        && s="${s} --top-p ${QWEN_TOP_P}"
  [[ -n "$QWEN_TOP_K" ]]        && s="${s} --top-k ${QWEN_TOP_K}"
  [[ -n "$QWEN_MIN_P" ]]        && s="${s} --min-p ${QWEN_MIN_P}"
  [[ -n "$QWEN_PRES_PENALTY" ]] && s="${s} --presence-penalty ${QWEN_PRES_PENALTY}"
  [[ -n "$QWEN_FREQ_PENALTY" ]] && s="${s} --frequency-penalty ${QWEN_FREQ_PENALTY}"
  [[ -n "$QWEN_THINKING" ]]     && s="${s} --thinking ${QWEN_THINKING}"
  echo "$s"
}
CLAUDE_SAMPLING="$(claude_sampling)"
QWEN_SAMPLING="$(qwen_sampling)"

build_cmds() {
  local p="$1"
  local CLAUDE_SPEC="Anthropic API (hosted)"
  local VAST_SPEC="1x RTX PRO 6000 Blackwell SE, 96GB, llama.cpp Qwen3.6-35B UD-Q8_K_XL MTP"
  local IDC_SPEC="2x RTX 3090, 48GB total, llama.cpp GGUF"
  CLAUDE_CMD="python3 '${STREAM}' --backend anthropic --label claude --url https://api.anthropic.com/v1 --model '${CLAUDE_MODEL}' --prompt-file '${p}' --api-key '${ANTHROPIC_API_KEY}' --max-tokens ${MAX_TOKENS} --countdown ${COUNTDOWN} --run --runner '${RUNNER}' --spec '${CLAUDE_SPEC}' --spec-file '${SPEC_FILE}' --log-file '${LOG_FILE}' ${CLAUDE_SAMPLING}"
  VAST_CMD="python3 '${STREAM}' --label blackwell --url http://${VAST_HOST}:${VAST_PORT}/v1 --model '${VAST_MODEL}' --prompt-file '${p}' --api-key 'EMPTY' --max-tokens ${MAX_TOKENS} --countdown ${COUNTDOWN} --run --runner '${RUNNER}' --spec '${VAST_SPEC}' --spec-file '${SPEC_FILE}' --log-file '${LOG_FILE}' ${QWEN_SAMPLING}"
  IDC_CMD="python3 '${STREAM}' --label 3090s --url http://${IDC_HOST}:${IDC_PORT}/v1 --model '${IDC_MODEL}' --prompt-file '${p}' --max-tokens ${MAX_TOKENS} --countdown ${COUNTDOWN} --run --runner '${RUNNER}' --spec '${IDC_SPEC}' --spec-file '${SPEC_FILE}' --log-file '${LOG_FILE}' ${QWEN_SAMPLING}"
}

write_prompt() {
  # Append a unique nonce line so every run has a fresh prompt prefix → no
  # prefix-cache / ephemeral-cache hit on vllm or Anthropic.
  local nonce p
  nonce="$(uuidgen 2>/dev/null || python3 -c 'import uuid; print(uuid.uuid4())')-$(date +%s%N)"
  p=$(mktemp -t llm_prompt.XXXXXX)
  { printf '%s\n\n# nonce: %s\n' "$1" "$nonce"; } > "$p"
  echo "$p"
}

cmd_start() {
  local prompt="$1" pfile
  pfile=$(write_prompt "$prompt")
  build_cmds "$pfile"
  # Capture session IDs as panes are created; print on stdout.
  local ids
  ids=$(/usr/bin/osascript <<APPLESCRIPT
tell application "iTerm2"
    tell current window
        tell current session
            set leftBottom to (split horizontally with default profile)
        end tell
        tell leftBottom
            set midBottom to (split vertically with default profile)
            write text "clear; ${CLAUDE_CMD//\"/\\\"}"
            tell midBottom
                set rightBottom to (split vertically with default profile)
                write text "clear; ${VAST_CMD//\"/\\\"}"
                tell rightBottom
                    write text "clear; ${IDC_CMD//\"/\\\"}"
                end tell
            end tell
        end tell
        return (unique id of leftBottom) & "|" & (unique id of midBottom) & "|" & (unique id of rightBottom)
    end tell
end tell
APPLESCRIPT
)
  echo "$ids" > "$STATE_FILE"
  echo "panes started + cached → $STATE_FILE"
  echo "prompt: $pfile"
}

cmd_go() {
  local prompt="$1" pfile
  [[ -s "$STATE_FILE" ]] || { echo "no cached panes; run: $0 start" >&2; exit 1; }
  IFS='|' read -r CL_ID VA_ID ID_ID < "$STATE_FILE"
  pfile=$(write_prompt "$prompt")
  build_cmds "$pfile"
  local matched
  matched=$(/usr/bin/osascript <<APPLESCRIPT
tell application "iTerm2"
    set hitCount to 0
    repeat with w in windows
        repeat with t in tabs of w
            repeat with s in sessions of t
                if unique id of s is "${CL_ID}" then
                    tell s to write text "clear; ${CLAUDE_CMD//\"/\\\"}"
                    set hitCount to hitCount + 1
                else if unique id of s is "${VA_ID}" then
                    tell s to write text "clear; ${VAST_CMD//\"/\\\"}"
                    set hitCount to hitCount + 1
                else if unique id of s is "${ID_ID}" then
                    tell s to write text "clear; ${IDC_CMD//\"/\\\"}"
                    set hitCount to hitCount + 1
                end if
            end repeat
        end repeat
    end repeat
    return hitCount
end tell
APPLESCRIPT
) || { echo "osascript failed" >&2; exit 1; }
  if [[ "$matched" != "3" ]]; then
    echo "panes lost (matched ${matched}/3) — clearing state, run: $0 start" >&2
    rm -f "$STATE_FILE"
    exit 1
  fi
  echo "go fired in cached panes | prompt: $pfile"
}

pick_random_lcb_spec() {
  local dir="${SCRIPT_DIR}/specs/lcb"
  local files=("${dir}"/p*.py)
  [[ -e "${files[0]}" ]] || { echo "no LCB specs in ${dir}; run: ${SCRIPT_DIR}/fetch_lcb.py" >&2; exit 1; }
  local pick="${files[RANDOM % ${#files[@]}]}"
  SPEC_FILE="$pick"
  SPEC_SRC="$(cat "$SPEC_FILE")"
  DEFAULT_PROMPT="Implement the Python class required by the canonical unittest spec below. Read the docstring + test method names + assertions to understand the API. Output ONLY the implementation — DO NOT include any tests, do NOT add 'if __name__' main block, do NOT redefine anything from the spec. Your code will be concatenated above the spec and executed.

\`\`\`python
${SPEC_SRC}
\`\`\`

CRITICAL: Every test in the spec MUST pass. Walk through each test against your implementation before finalising. Handle every edge case the tests cover."
  echo "lcb spec: $(basename "$SPEC_FILE")"
}

main() {
  local sub="${1:-auto}"; shift || true
  local prompt
  case "$sub" in
    start)
      prompt="${1:-$DEFAULT_PROMPT}"
      cmd_start "$prompt" ;;
    lcb)
      pick_random_lcb_spec
      if [[ -s "$STATE_FILE" ]]; then cmd_go "$DEFAULT_PROMPT"; else cmd_start "$DEFAULT_PROMPT"; fi ;;
    go)
      prompt="${1:-$DEFAULT_PROMPT}"
      cmd_go "$prompt" ;;
    reset)
      rm -f "$STATE_FILE"; echo "state cleared" ;;
    auto)
      prompt="$DEFAULT_PROMPT"
      if [[ -s "$STATE_FILE" ]]; then cmd_go "$prompt"; else cmd_start "$prompt"; fi ;;
    -h|--help|help)
      sed -n '2,12p' "$0" ;;
    *)
      prompt="$sub"
      if [[ -s "$STATE_FILE" ]]; then cmd_go "$prompt"; else cmd_start "$prompt"; fi ;;
  esac
}
main "$@"
